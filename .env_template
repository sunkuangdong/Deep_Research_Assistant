# Deep Research Assistant 环境变量模板
# 用法：cp .env_template .env  然后填入真实值
# 注意：.env 不要提交到 Git

# ---- 必填：LLM（OpenAI 兼容）----
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4.1-mini
MODEL_MAX_INPUT_TOKENS=131072

# ---- 必填：联网搜索（Bocha）----
BOCHA_API_KEY=

# ---- 可选：LangSmith 观测 ----
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=deep-research-assistant

# ---- 可选：本地 Ollama 示例（取消注释并注释掉上方官方配置）----
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama-local-key
# MODEL_NAME=qwen2.5:7b
