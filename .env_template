# Deep Research Assistant — environment variable template (English)
# Usage: cp .env_template .env  then fill in real values
# Do NOT commit .env to Git

# ---- Required: LLM (OpenAI-compatible) ----
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4.1-mini
MODEL_MAX_INPUT_TOKENS=131072

# ---- Required: web search (Bocha) ----
BOCHA_API_KEY=

# ---- Optional: LangSmith tracing ----
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=deep-research-assistant

# ---- Optional: local Ollama example ----
# Uncomment below and comment out the official OpenAI settings above.
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama-local-key
# MODEL_NAME=qwen2.5:7b
